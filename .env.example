# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# JWT
JWT_SECRET=change-me-in-production-min-16-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30

# Google OAuth (Web client ID from Google Cloud Console).
# Leave blank to disable /auth/google-login.
GOOGLE_CLIENT_ID=

# GitHub OAuth (from https://github.com/settings/developers).
# Leave blank to disable /auth/github-login.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Must match the OAuth app's callback URL. For mobile deep-link flow:
GITHUB_REDIRECT_URI=codelab://oauth/github

# Facebook Login (from https://developers.facebook.com/apps).
# Leave blank to disable /auth/facebook-login.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Database
DATABASE_URL=postgresql://edtronaut:edtronaut_secret@localhost:5432/live_code_execution?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# Execution Limits
EXEC_TIMEOUT_MS=10000
EXEC_MAX_MEMORY_KB=262144
EXEC_MAX_OUTPUT_BYTES=1048576
EXEC_MAX_RETRIES=2
EXEC_MAX_PIDS=10

# Rate Limiting
RATE_LIMIT_EXECUTIONS_PER_MINUTE=10
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_COOLDOWN_AFTER_TIMEOUTS=3
RATE_LIMIT_COOLDOWN_SECONDS=60

# Session
SESSION_MAX_CODE_SIZE_BYTES=51200
SESSION_TTL_HOURS=4
SESSION_MAX_SNAPSHOTS=50

# Queue
QUEUE_NAME=code-execution
QUEUE_JOB_TTL_MS=300000
QUEUE_CONCURRENCY=5
